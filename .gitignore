# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Claude Code internal (exceto skills customizadas)
.claude/*
!.claude/skills

# Temp folder (local)
temp

# Runs locais (fora de exemplos/)
*_new_*/
*_s_*/
search_*.csv
sc_*.csv
sc_*_params.json

# Python version pin (local)
.python-version

# Ferramentas de sessão (Claude Code, Trae, etc.)
.agents/
.trae/
skills-lock.json

# Assets opcionais (gerados por --export-template; não necessários para execução)
assets/
